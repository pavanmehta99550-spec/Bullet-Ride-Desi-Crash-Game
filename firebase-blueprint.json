{
  "entities": {
    "user": {
      "title": "User Profile",
      "description": "Stores user balance, profile, referral progress, and deposit status",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "walletBalance": { "type": "number", "description": "Available game balance" },
        "bonus_balance": { "type": "number", "description": "Promotional bonus balance, not withdrawable" },
        "has_deposited": { "type": "boolean", "description": "Has made at least one approved deposit" },
        "referredBy": { "type": "string", "description": "UID of the user who referred this player" },
        "referralCode": { "type": "string", "description": "Unique referral code for sharing" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "walletBalance"]
    },
    "gameResult": {
      "title": "Game Record",
      "description": "A single round result for a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "betAmount": { "type": "number" },
        "multiplier": { "type": "number" },
        "winAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["win", "loss"] }
      },
      "required": ["id", "timestamp", "betAmount", "multiplier", "winAmount", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user",
      "description": "Primary user profile"
    },
    "/users/{userId}/history/{gameId}": {
      "schema": "gameResult",
      "description": "User game history"
    },
    "/game/{gameId}": {
      "schema": { "type": "object", "properties": { "status": { "type": "string" }, "roundId": { "type": "string" }, "crashPoint": { "type": "number" } } },
      "description": "Current active game state"
    },
    "/globalHistory/{roundId}": {
      "schema": { "type": "object", "properties": { "id": { "type": "string" }, "multiplier": { "type": "number" } } },
      "description": "Public history of all rounds"
    },
    "/admins/{userId}": {
      "schema": { "type": "object", "properties": { "role": { "type": "string" } } },
      "description": "Admin access control"
    }
  }
}
