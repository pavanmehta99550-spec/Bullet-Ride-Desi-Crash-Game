rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "pavanmehta99550@gmail.com" ||
        request.auth.uid == "AaTDD2FuYzRu6BrqcWhX89vl5HH2" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // --- Entity Validations ---

    function isValidUser(data, userId) {
      return data.uid == userId 
        && (data.email is string && data.email.size() <= 100)
        && (data.displayName is string && data.displayName.size() <= 100)
        && data.walletBalance is number
        && data.createdAt is timestamp;
    }

    function isValidGameResult(data) {
      return data.id is string && data.id.size() <= 100
        && (data.timestamp is timestamp || data.timestamp == null)
        && (data.createdAt is number || !('createdAt' in data))
        && data.betAmount is number
        && data.multiplier is number
        && data.winAmount is number
        && data.status in ['win', 'loss'];
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId)
        && isValidId(userId)
        && isValidUser(incoming(), userId)
        && incoming().keys().hasAll(['uid', 'email', 'displayName', 'walletBalance', 'createdAt'])
        && incoming().keys().size() >= 5;

      allow update: if isAdmin();
      allow update: if isOwner(userId)
        && isValidUser(incoming(), userId)
        && incoming().createdAt == existing().createdAt
        && incoming().uid == existing().uid
        && incoming().diff(existing()).affectedKeys().hasOnly(['walletBalance', 'displayName', 'updatedAt', 'coinBalances', 'activeCoin'])
        && (incoming().get('updatedAt', null) == request.time || !incoming().keys().hasAny(['updatedAt']));
    }

    match /users/{userId}/history/{gameId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId);
      
      allow create: if isOwner(userId)
        && isValidId(userId)
        && isValidId(gameId)
        && isValidGameResult(incoming())
        && incoming().keys().hasAll(['id', 'timestamp', 'betAmount', 'multiplier', 'winAmount', 'status'])
        && incoming().keys().size() >= 6 && incoming().keys().size() <= 8;
      
      // History is immutable
      allow update, delete: if false;
    }

    match /deposits/{depositId} {
      allow list, get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /withdrawals/{withdrawalId} {
      allow list, get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow list, get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }
  }
}
