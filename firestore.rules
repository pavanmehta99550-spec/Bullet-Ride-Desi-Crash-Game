rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.uid == request.auth.uid 
        && data.email is string && data.email.size() <= 100
        && data.displayName is string && data.displayName.size() <= 100
        && data.walletBalance is number
        && data.createdAt is timestamp;
    }

    function isValidGameResult(data) {
      return data.id is string && data.id.size() <= 100
        && data.timestamp is timestamp
        && data.betAmount is number
        && data.multiplier is number
        && data.winAmount is number
        && data.status in ['win', 'loss'];
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId)
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().keys().hasAll(['uid', 'email', 'displayName', 'walletBalance', 'createdAt'])
        && incoming().keys().size() == 5;

      allow update: if (isOwner(userId) || isAdmin())
        && isValidUser(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().uid == existing().uid
        && (isAdmin() || incoming().diff(existing()).affectedKeys().hasOnly(['walletBalance', 'displayName', 'updatedAt']))
        && (incoming().get('updatedAt', null) == request.time || !incoming().keys().hasAny(['updatedAt']));
    }

    match /users/{userId}/history/{gameId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId);
      
      allow create: if isOwner(userId)
        && isValidId(userId)
        && isValidId(gameId)
        && isValidGameResult(incoming())
        && incoming().keys().hasAll(['id', 'timestamp', 'betAmount', 'multiplier', 'winAmount', 'status'])
        && incoming().keys().size() == 6;
      
      // History is immutable
      allow update, delete: if false;
    }
  }
}
